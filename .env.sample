# ─────────────────────────────────────────────────────────────────────────────
# Telegram credentials
# Get API_ID and API_HASH from https://my.telegram.org
# ─────────────────────────────────────────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token from @BotFather on Telegram
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# MongoDB
# Free cluster at https://www.mongodb.com/atlas
# ─────────────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=filesearchbot

# ─────────────────────────────────────────────────────────────────────────────
# DB Channel
# The Telegram channel where all your files live.
# Must be a numeric ID (e.g., -1001234567890).
# The bot must be an ADMIN of this channel to read history and copy files.
# ─────────────────────────────────────────────────────────────────────────────
DB_CHANNEL_ID=-1001234567890

# ─────────────────────────────────────────────────────────────────────────────
# Force join (optional)
# Channel username WITHOUT the @ sign.
# Users must join this channel before using the bot.
# Leave empty to disable.
# ─────────────────────────────────────────────────────────────────────────────
FORCE_JOIN_CHANNEL=

# ─────────────────────────────────────────────────────────────────────────────
# Admins
# Comma-separated Telegram user IDs who can run /index, /stats, /deleteindex
# ─────────────────────────────────────────────────────────────────────────────
ADMINS=123456789,987654321

# ─────────────────────────────────────────────────────────────────────────────
# Pagination
# Number of results shown per page (default 10)
# ─────────────────────────────────────────────────────────────────────────────
RESULTS_PER_PAGE=10
